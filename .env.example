PORT=3000
ADMIN_USERNAME=admin
# Gere interativamente com: npm run password:hash
# Nunca coloque a senha em texto puro neste arquivo.
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$COLE_AQUI_O_SALT_E_HASH_GERADOS
SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio
# Somente para testes temporários. Nunca use true em produção.
ALLOW_INSECURE_TUNNEL=false
# Em produção com HTTPS, use true.
COOKIE_SECURE=false
# Proteção contra força bruta no login. O bloqueio usa IP e conta separadamente.
LOGIN_MAX_ATTEMPTS_PER_IP=5
LOGIN_MAX_ATTEMPTS_PER_ACCOUNT=10
LOGIN_ATTEMPT_WINDOW_MINUTES=15
# Limite total por arquivo e configuração do upload retomável.
MAX_FILE_SIZE_GB=50
UPLOAD_CHUNK_SIZE_MB=8
UPLOAD_CONCURRENCY=3
# Sessões incompletas permanecem disponíveis para retomada por 72 horas.
UPLOAD_SESSION_TTL_HOURS=72
# Arquivos de texto acima deste tamanho continuam disponíveis para download,
# mas não são abertos no editor do navegador.
MAX_EDITABLE_TEXT_MB=5
# Prévia pública somente leitura; arquivos maiores continuam disponíveis para download.
MAX_PUBLIC_TEXT_PREVIEW_MB=1
# PDF, DOCX, XLSX e dados estruturados usam parsing isolado e um limite próprio.
MAX_PUBLIC_DOCUMENT_PREVIEW_MB=10
# Ferramentas públicas: limites mantidos baixos para proteger CPU e memória.
MAX_DOCUMENT_CONVERSION_MB=10
MAX_IMAGE_CONVERSION_MB=12
